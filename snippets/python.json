{
    "shebang": { "prefix": "#!", "body": "#!/usr/bin/env python3" },
    "coding": { "prefix": "#u", "body": "# coding: utf-8" },
    "inline script metadata": {
        "prefix": "#s",
        "body": ["# /// script", "# $0", "# ///"]
    },
    "self": {
        "prefix": "s.",
        "body": "self.$0"
    },
    "if main": {
        "prefix": "ifm",
        "body": ["if __name__ == '__main__':", "\t${0:main}"]
    },
    "logging.debug": {
        "prefix": "logd",
        "body": "logging.debug($0)"
    },
    "logging.info": {
        "prefix": "logi",
        "body": "logging.info($0)"
    },
    "logging.warning": {
        "prefix": "logw",
        "body": "logging.warning($0)"
    },
    "logging.error": {
        "prefix": "logw",
        "body": "logging.error($0)"
    },
    "with": {
        "prefix": "with",
        "body": ["with $1 as $2:", "\t${0:pass}"]
    },
    "with open": {
        "prefix": "wop",
        "body": [
            "with open($1, '${2:r}', encoding='${3:utf-8}'$4) as $5:",
            "\t${0:pass}"
        ]
    },
    "from typing": {
        "prefix": "frtyp",
        "body": "from typing import Optional, Union, Dict, List, Set, Tuple, Any, Callable, Iterable, NamedTuple"
    }
}
